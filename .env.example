DATABASE_URL=postgresql://abr:abr@localhost:5432/abr_import
INPUT_DIR=./data/input
ARCHIVE_DIR=./data/archive

# OCR на CPU (GPU отдан Ollama)
USE_GPU=false
OCR_LANG=ru
PDF_DPI=200

# llm | rules
EXTRACTOR=llm
OLLAMA_URL=http://localhost:11434
# 11GB VRAM: llama3.1:8b (рекомендуется) или qwen2.5:14b-instruct-q4_K_M
OLLAMA_MODEL=llama3.1:8b
LLM_CHUNK_PAGES=4
LLM_MAX_CHARS=12000
LLM_TIMEOUT_SEC=600

ZIP_FILENAME_ENCODING=auto
ZIP_FORCE_REEXTRACT=false
STALE_PROCESSING_MINUTES=120
POLL_INTERVAL_SEC=10
